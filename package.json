{
  "name": "online-belote",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --port 3000",
    "build": "tsr generate && vite build",
    "type-check": "tsr generate && tsc --noEmit",
    "generate-routes": "tsr generate",
    "watch-routes": "tsr watch",
    "serve": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier",
    "check": "prettier --write . && eslint --fix"
  },
  "dependencies": {
    "@gsap/react": "2.1.2",
    "@microsoft/signalr": "9.0.6",
    "@nkzw/liquid-glass": "1.3.0",
    "@tailwindcss/vite": "4.1.18",
    "@tanstack/react-devtools": "0.7.11",
    "@tanstack/react-router": "1.149.3",
    "@tanstack/react-router-devtools": "1.149.3",
    "@tanstack/router-plugin": "1.149.3",
    "axios": "1.16.1",
    "gsap": "3.14.2",
    "lucide-react": "0.545.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwindcss": "4.1.18"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@tanstack/eslint-config": "0.3.4",
    "@tanstack/router-cli": "1.157.18",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.1",
    "@types/node": "22.19.6",
    "@types/react": "19.2.8",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.2",
    "eslint": "9.39.2",
    "jsdom": "27.4.0",
    "prettier": "3.7.4",
    "typescript": "5.9.3",
    "vite": "7.3.3",
    "vitest": "3.2.4",
    "web-vitals": "5.1.0"
  }
}
